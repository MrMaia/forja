{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forja",
  "version": "0.1.4",
  "identifier": "com.allanmaia.forja",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Forja",
        "width": 1280,
        "height": 800,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "resources": {
      "resources/wifi-intel.exe": "drivers/wifi-intel.exe"
    }
  },
  "plugins": {}
}
