{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissões padrão da Forja: shell para winget, dialog/fs para perfis .forja, os para info do sistema.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "os:default",
    "dialog:default",
    "fs:default",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "winget",
          "cmd": "winget",
          "args": [
            "install",
            "--id",
            { "validator": "^[A-Za-z0-9.\\-_+]+$" },
            "-e",
            "--silent",
            "--accept-package-agreements",
            "--accept-source-agreements"
          ]
        },
        {
          "name": "winget-upgrade",
          "cmd": "winget",
          "args": [
            "upgrade",
            "--id",
            { "validator": "^[A-Za-z0-9.\\-_+]+$" },
            "-e",
            "--silent",
            "--accept-package-agreements",
            "--accept-source-agreements"
          ]
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "winget-list",
          "cmd": "winget",
          "args": ["list", "--accept-source-agreements"]
        },
        {
          "name": "set-user-path",
          "cmd": "powershell",
          "args": [
            "-NoProfile",
            "-NonInteractive",
            "-ExecutionPolicy",
            "Bypass",
            "-Command",
            "$d=$env:FORJA_PATH_DIR; if($d){ $p=[Environment]::GetEnvironmentVariable('Path','User'); if(-not $p){$p=''}; if(($p -split ';') -notcontains $d){ [Environment]::SetEnvironmentVariable('Path', ($p.TrimEnd(';')+';'+$d), 'User') } }"
          ]
        }
      ]
    }
  ]
}
